# ─────────────────────────────────────────────────────────────────────────────
# Polymarket Dual Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PAPER TESTING (only this section needed to start) ─────────────────────────

# Alchemy free tier — Ethereum Mainnet
# Get it at: https://dashboard.alchemy.com → Create App → Ethereum Mainnet
# Copy the HTTPS URL exactly as shown
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/OGOyrM3TkmlP943B-ZLDi
ALCHEMY_API_KEY=OGOyrM3TkmlP943B-ZLDi

# ── LIVE TRADING ONLY (leave blank during paper testing) ─────────────────────

# Your Magic Link wallet private key (WITHOUT the 0x prefix)
# Export at: https://reveal.magic.link/polymarket
# WARNING: Never share this with anyone. Never screenshot it.
POLYMARKET_PRIVATE_KEY=0x07ccf551112c046816b27ae3a01c0adf32f27e27b38eed63e80a2ba824fdc1d6

# Your Polymarket funder address (the address shown in your Polymarket profile)
# This is different from your Magic wallet address — see README for explanation
POLYMARKET_FUNDER_ADDRESS=0xaf6Ffb5356cD6bfE92D7b8f85Ab56dC0fC18333d

# Polymarket API credentials
# Generated by running: python scripts/get_api_key.py  (after setting PK above)
POLYMARKET_API_KEY=6b1afb2c-53ef-8bf7-d8ab-4db93775e5b2
POLYMARKET_API_SECRET=iGp8NmlJKh5GBwOgGM1lqvDM9GTuJCwAH34sOwSz-JA=
POLYMARKET_PASSPHRASE=4dc0ea447d41b5a1d5e55b89e9147ad57fd357fa830f13bc60357d999659f592

MAX_CONSECUTIVE_LOSSES=100

# ── Circuit Breaker Settings ─────────────────────────────────────────────────

# Paper vs Live Trading Mode
PAPER_TRADING=true

# Profit Ratchet (Trailing Stop)
# 6% profit to activate ratchet
PROFIT_RATCHET_THRESHOLD=0.06
# 1% drawdown from peak triggers halt
TRAILING_STOP_PCT=0.01
# Optional 50% hard cap (0 to disable)
MAX_DAILY_PROFIT_PCT=0.50

# Loss Protection
# 15% settled loss limit
DAILY_LOSS_LIMIT_PCT=0.15
# Lock duration after loss limit hit (160 minutes)
GLOBAL_HALT_DURATION_MINUTES=160

# P&L Monitoring
# Check every 10 seconds
PNL_CHECK_INTERVAL_SEC=10
PNL_ERROR_LOG_PATH=logs/pnl_errors.log

# Global Profit Targets
# 10% realized profit target
GLOBAL_DAILY_PROFIT_TARGET=0.10
# 20% unrealized profit spike target
GLOBAL_UNREALIZED_PROFIT_TARGET=0.20
